<?xml version="1.0" encoding="utf-8"?>
<!-- Layout Home dengan Tema Material Modern -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/purple_500"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <TextView
                android:id="@+id/tv_judul"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="Form Biodata Mahasiswa"
                android:textAlignment="center"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Nama Lengkap -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Nama Lengkap"
            app:boxStrokeColor="@color/purple_500"
            app:hintTextColor="@color/purple_700">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_nama"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Masukkan nama lengkap"
                android:textColorHint="#000000"
                android:textColor="@color/black" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- NIM -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="NIM"
            app:boxStrokeColor="@color/purple_500">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_nim"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:hint="Masukkan Nim"
                android:textColorHint="#000000"
                android:textColor="@color/black" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Prodi -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Program Studi"
            app:boxStrokeColor="@color/purple_500">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_prodi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Prodi"
                android:textColorHint="#000000"
                android:textColor="@color/black" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Angkatan -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Angkatan"
            app:boxStrokeColor="@color/purple_500">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_angkatan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:hint="Masukkan Angkata"
                android:textColorHint="#888888"
                android:textColor="@color/black" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Container untuk Pilihan Radio & Checkbox -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_border"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jenis Kelamin"
                android:textColor="@color/purple_700"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>
            <RadioGroup
                android:id="@+id/rg_jk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <RadioButton android:id="@+id/rb_laki" android:text="Laki-laki" android:textColor="@color/black" android:layout_weight="1"/>
                <RadioButton android:id="@+id/rb_perempuan" android:text="Perempuan" android:textColor="@color/black" android:layout_weight="1"/>
            </RadioGroup>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginVertical="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hobi"
                android:textColor="@color/purple_700"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>
            <CheckBox android:id="@+id/cb1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Baca Buku" android:textColor="@color/black"/>
            <CheckBox android:id="@+id/cb2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Olahraga" android:textColor="@color/black"/>
            <CheckBox android:id="@+id/cb3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Belajar" android:textColor="@color/black"/>
        </LinearLayout>

        <!-- Alamat -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Alamat Lengkap"
            app:boxStrokeColor="@color/purple_500">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_alamat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Masukkan alamat lengkap"
                android:textColorHint="@color/black"
                android:textColor="@color/black" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Spinner Kota -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kota"
            android:textColor="@color/purple_700"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:strokeWidth="1dp"
            app:strokeColor="#DADCE0"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">
            <Spinner
                android:id="@+id/sp_kota"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:paddingStart="8dp"
                android:background="@android:color/transparent" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Spinner Provinsi -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Provinsi"
            android:textColor="@color/purple_700"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:strokeWidth="1dp"
            app:strokeColor="#DADCE0"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">
            <Spinner
                android:id="@+id/sp_provinsi"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:paddingStart="8dp"
                android:background="@android:color/transparent" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Tombol Aksi -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_simpan"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="SIMPAN"
                android:textSize="16sp"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_tampil"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="LIHAT"
                android:textSize="16sp"
                app:cornerRadius="12dp"
                app:strokeColor="@color/purple_500" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>